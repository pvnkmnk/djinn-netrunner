# Copy to .env and adjust for your deployment mode (see comments below).

# --- Required ---
# Docker Compose (production/default stack): use PostgreSQL URL matching docker-compose.yml
DATABASE_URL=postgresql://musicops:changeme_secure_password@postgres:5432/musicops?sslmode=disable
POSTGRES_PASSWORD=changeme_secure_password

# Local single-binary dev (SQLite): comment the line above and use a file path instead
# DATABASE_URL=netrunner.db

# Session signing secret (persist across restarts)
JWT_SECRET=replace_with_a_long_random_secret

# slskd Soulseek credentials
SLSKD_USERNAME=your_soulseek_username
SLSKD_PASSWORD=your_soulseek_password
SLSKD_API_KEY=generate_random_api_key

# --- Server / edge ---
ENVIRONMENT=development
CONFIG_ENV=development
PORT=8080
DOMAIN=localhost

# --- Library & templates (defaults work for repo checkout) ---
MUSIC_LIBRARY=./music_library
TEMPLATES_PATH=./ops/web/templates
STATIC_FILES_PATH=./ops/web/static

# --- Optional integrations ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8080/api/auth/spotify/callback
SLSKD_URL=http://localhost:5030
GONIC_URL=http://localhost:4747
GONIC_USER=
GONIC_PASS=
MUSICBRAINZ_USER_AGENT=NetRunner/1.0.0 (contact@example.com)
MUSICBRAINZ_API_KEY=
ACOUSTID_API_KEY=
LASTFM_API_KEY=
LISTENBRAINZ_TOKEN=
DISCOGS_TOKEN=
LIDARR_URL=
LIDARR_API_KEY=
# YT-DLP
YTDLP_PATH=yt-dlp
# Navidrome (alternative to Gonic — set URL to enable)
NAVIDROME_URL=
NAVIDROME_USER=
NAVIDROME_PASS=
PROXY_URL=

# --- Notifications ---
NOTIFICATION_ENABLED=false
NOTIFICATION_WEBHOOK_URL=

# --- SMTP (email notifications — set SMTP_ENABLED=true to activate) ---
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Auth rate limiting (Fiber in-memory limiter on login/register) ---
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_EXPIRATION=1m

# --- Reserved (not required for current runtime) ---
REDIS_URL=redis://localhost:6379
